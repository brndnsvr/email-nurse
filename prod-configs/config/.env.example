# Email Nurse Configuration
# Environment variables with EMAIL_NURSE_ prefix
# Copy to .env and fill in secrets

# AI Provider: claude, openai, or ollama
EMAIL_NURSE_AI_PROVIDER=claude

# Claude settings
EMAIL_NURSE_CLAUDE_MODEL=claude-haiku-4-5-20251001

# Ollama settings
EMAIL_NURSE_OLLAMA_HOST=http://localhost:11434
EMAIL_NURSE_OLLAMA_MODEL=mistral:7b-instruct-v0.3-q8_0

# SMTP settings for Gmail (daily digest email)
EMAIL_NURSE_SMTP_ENABLED=true
EMAIL_NURSE_SMTP_HOST=smtp.gmail.com
EMAIL_NURSE_SMTP_PORT=587
EMAIL_NURSE_SMTP_USE_TLS=true
EMAIL_NURSE_SMTP_USERNAME=your-email@gmail.com
EMAIL_NURSE_SMTP_PASSWORD="your-app-password"
EMAIL_NURSE_SMTP_FROM_ADDRESS=your-email@gmail.com

# Message retrieval provider: applescript, sysm, hybrid
EMAIL_NURSE_MESSAGE_PROVIDER=sysm

# Report settings
EMAIL_NURSE_REPORT_RECIPIENT=your-email@icloud.com
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
